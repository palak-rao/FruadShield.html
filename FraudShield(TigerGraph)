    const a=nm[e.a],b=nm[e.b];if(!a||!b)return;
    ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
    ctx.strokeStyle=e.fr?'rgba(255,136,136,0.45)':'rgba(180,140,255,0.18)';ctx.lineWidth=e.fr?2:1;ctx.stroke();
    const mx=(a.x+b.x)/2,my=(a.y+b.y)/2,dx=b.x-a.x,dy=b.y-a.y,len=Math.sqrt(dx*dx+dy*dy)||1;
    const nx=dx/len*6,ny=dy/len*6;
    ctx.beginPath();ctx.moveTo(mx+nx,my+ny);ctx.lineTo(mx-ny*.5+nx*-.5,my+nx*.5+ny*-.5);ctx.lineTo(mx+ny*.5+nx*-.5,my-nx*.5+ny*-.5);
    ctx.fillStyle=e.fr?'rgba(255,136,136,.6)':'rgba(180,140,255,.4)';ctx.fill();
  });
  vn.forEach(n=>{
    const col=nodeColor(n);
    if(n.fr){ctx.beginPath();ctx.arc(n.x,n.y,18,0,Math.PI*2);ctx.fillStyle='rgba(255,136,136,.07)';ctx.fill();}
    ctx.beginPath();ctx.arc(n.x,n.y,10,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();
    ctx.beginPath();ctx.arc(n.x,n.y,10,0,Math.PI*2);ctx.strokeStyle=n.fr?'rgba(255,136,136,.45)':'rgba(255,255,255,.1)';ctx.lineWidth=n.fr?2:1;ctx.stroke();
    ctx.fillStyle='#DDD6FE';ctx.font='9px Segoe UI';ctx.textAlign='center';ctx.fillText(n.lbl,n.x,n.y+22);
  });
}
