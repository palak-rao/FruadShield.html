let gn2=[...GN.map(n=>({...n,vx:0,vy:0}))],ge2=[...GE],af=null,nc=12;
function initG2(){
  const c=document.getElementById('gc2');if(!c)return;
  c.width=c.offsetWidth||540;c.height=c.parentElement?c.parentElement.offsetHeight-100:460;
  if(c.height<200)c.height=460;
  layoutN(gn2,c.width,c.height);
  if(af)cancelAnimationFrame(af);
  function tick(){
    gn2.forEach(n=>{gn2.forEach(m=>{if(n===m)return;const dx=n.x-m.x,dy=n.y-m.y,d=Math.sqrt(dx*dx+dy*dy)||1;if(d<65){const f=(65-d)/65*.35;n.vx+=dx/d*f;n.vy+=dy/d*f;}});n.vx*=.83;n.vy*=.83;n.x+=n.vx;n.y+=n.vy;n.x=Math.max(16,Math.min(c.width-16,n.x));n.y=Math.max(16,Math.min(c.height-16,n.y));});
    const ctx=c.getContext('2d');ctx.clearRect(0,0,c.width,c.height);ctx.fillStyle='#080115';ctx.fillRect(0,0,c.width,c.height);
    const nm={};gn2.forEach(n=>nm[n.id]=n);
    ge2.forEach(e=>{const a=nm[e.a],b=nm[e.b];if(!a||!b)return;ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=e.fr?'rgba(255,136,136,.5)':'rgba(180,140,255,.18)';ctx.lineWidth=e.fr?2:1;ctx.stroke();});
    gn2.forEach(n=>{const col=nodeColor(n);if(n.fr){ctx.beginPath();ctx.arc(n.x,n.y,16,0,Math.PI*2);ctx.fillStyle='rgba(255,136,136,.06)';ctx.fill();}ctx.beginPath();ctx.arc(n.x,n.y,9,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();ctx.fillStyle='#DDD6FE';ctx.font='9px Segoe UI';ctx.textAlign='center';ctx.fillText(n.lbl,n.x,n.y+20);});
    af=requestAnimationFrame(tick);
  }tick();
}
