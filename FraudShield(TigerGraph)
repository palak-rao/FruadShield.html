**FraudShield (Fraud Detection Dashboard)Tiger Graph
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#0D0618;--bg2:#130920;--bg3:#1A0D2E;--bg4:#221140;
--card:#160B28;--card2:#1E1038;--card3:#0A0412;
--p:#9B6DFF;--p2:#7C4FE0;--p3:#B48CFF;--p4:#C9AEFF;--p5:#E0D0FF;
--lav:#EAE0FF;--lav2:#F5F0FF;
--danger:#E05555;--danger2:#A03030;--danger3:#3A1010;
--success:#3DB882;--success2:#1A5C40;
--warn:#C9881A;--warn2:#5C3800;
--txt:#EEE6FF;--txt2:#B89FE8;--txt3:#6B4F9C;
--border:rgba(180,140,255,0.12);--border2:rgba(180,140,255,0.25);--border3:rgba(180,140,255,0.45);
--accent1:#7B3FF5;--accent2:#A855F7;--white:#FFFFFF;
--radius:16px;--radius2:11px;--radius3:7px;
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--txt);overflow-x:hidden;min-height:100vh}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideR{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:translateX(0)}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(155,109,255,.45)}50%{box-shadow:0 0 0 8px rgba(155,109,255,0)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
@keyframes scan{0%{top:-2px}100%{top:100%}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.au{animation:fadeUp .4s ease forwards}
.au2{animation:fadeUp .4s .08s ease both}
.au3{animation:fadeUp .4s .16s ease both}
input,textarea,select{background:var(--card2);border:1px solid var(--border2);color:var(--txt);border-radius:var(--radius2);padding:10px 13px;font-size:13px;width:100%;outline:none;transition:border .18s,box-shadow .18s;font-family:inherit}
input:focus,textarea:focus,select:focus{border-color:var(--p3);box-shadow:0 0 0 3px rgba(155,109,255,.13)}
input::placeholder{color:var(--txt3)}
select option{background:var(--card2)}
button{cursor:pointer;border:none;border-radius:var(--radius2);padding:10px 20px;font-size:13px;font-weight:600;transition:all .16s;font-family:inherit}
.bp{background:var(--p);color:#fff}
.bp:hover{background:var(--p2);transform:translateY(-1px)}
.bo{background:transparent;border:1px solid var(--border2);color:var(--txt2)}
.bo:hover{background:var(--card2);border-color:var(--p3)}
.bd{background:var(--danger);color:#fff}
.tag{display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.3px}
.td{background:var(--danger3);color:#FFAAAA;border:1px solid rgba(224,85,85,.35)}
.ts{background:#3A2500;color:#FFD070;border:1px solid rgba(201,136,26,.35)}
.tg{background:#0D3025;color:#5DEDB5;border:1px solid rgba(61,184,130,.35)}
.tp{background:var(--card2);color:var(--p4);border:1px solid var(--border2)}
.tw{background:#3A1500;color:#FFAA70;border:1px solid rgba(224,130,85,.35)}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:border .18s}
.card:hover{border-color:var(--border2)}
.scan-line{position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(180,140,255,.25),transparent);animation:scan 5s linear infinite;pointer-events:none;z-index:2}
.toast-wrap{position:absolute;bottom:18px;right:18px;z-index:9999;display:flex;flex-direction:column;gap:6px}
.toast{background:var(--card3);border:1px solid var(--border3);border-radius:var(--radius2);padding:10px 14px;font-size:12px;color:var(--txt);min-width:250px;animation:slideR .25s ease;display:flex;align-items:center;gap:8px}
.toast.success{border-left:3px solid var(--success)}
.toast.error{border-left:3px solid var(--danger)}
.toast.info{border-left:3px solid var(--p3)}

.page{display:none;min-height:100vh;width:100%}
.page.active{display:flex}

.auth-page{flex-direction:row;min-height:100vh}
.auth-l{flex:1;background:var(--bg2);display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px 32px;position:relative;overflow:hidden}
.auth-grid{position:absolute;inset:0;opacity:.03;background-image:linear-gradient(var(--p3) 1px,transparent 1px),linear-gradient(90deg,var(--p3) 1px,transparent 1px);background-size:40px 40px}
.auth-r{width:440px;display:flex;flex-direction:column;justify-content:center;padding:48px 40px;background:var(--bg);overflow-y:auto}
.logo-row{display:flex;align-items:center;gap:9px;margin-bottom:40px;z-index:1}
.logo-sq{width:40px;height:40px;background:var(--p);border-radius:11px;display:flex;align-items:center;justify-content:center}
.logo-nm{font-size:18px;font-weight:700;color:var(--white)}
.auth-orb{width:150px;height:150px;border-radius:50%;border:1px solid rgba(180,140,255,.18);display:flex;align-items:center;justify-content:center;position:relative;margin:0 auto 20px;animation:float 4s ease-in-out infinite;z-index:1}
.auth-orb-in{width:100px;height:100px;background:rgba(155,109,255,.1);border-radius:50%;display:flex;align-items:center;justify-content:center;border:1px solid rgba(180,140,255,.15)}
.flabel{display:block;font-size:11px;font-weight:700;color:var(--txt3);margin-bottom:4px;text-transform:uppercase;letter-spacing:.6px}
.fgroup{margin-bottom:13px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fdivider{display:flex;align-items:center;gap:8px;margin:14px 0;color:var(--txt3);font-size:11px}
.fdivider::before,.fdivider::after{content:'';flex:1;height:1px;background:var(--border)}
.sw{text-align:center;margin-top:16px;font-size:13px;color:var(--txt3)}
.sw span{color:var(--p3);font-weight:600;cursor:pointer}
.inp-wrap{position:relative}
.eye-btn{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--txt3);padding:3px;width:auto;cursor:pointer}
.str-bar{height:3px;border-radius:2px;background:var(--bg3);margin-top:5px;overflow:hidden}
.str-fill{height:100%;border-radius:2px;transition:width .3s,background .3s}

.sidebar{width:225px;background:var(--card3);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.sb-logo{display:flex;align-items:center;gap:8px;padding:18px 16px;border-bottom:1px solid var(--border)}
.sb-logo-sq{width:30px;height:30px;background:var(--p);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo-txt{font-size:13px;font-weight:700;color:var(--white)}
.sb-ver{font-size:9px;padding:2px 5px;background:rgba(155,109,255,.2);color:var(--p5);border-radius:8px;margin-left:3px}
.nav-sec{padding:12px 8px 4px}
.nav-lbl{font-size:10px;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.7px;padding:0 6px;margin-bottom:4px}
.ni{display:flex;align-items:center;gap:8px;padding:8px 9px;border-radius:var(--radius3);color:var(--txt3);font-size:12px;font-weight:500;transition:all .16s;margin-bottom:1px;cursor:pointer}
.ni:hover{background:rgba(180,140,255,.07);color:var(--txt2)}
.ni.act{background:rgba(155,109,255,.18);color:var(--p5)}
.ni-ico{width:14px;height:14px;flex-shrink:0}
.nbadge{margin-left:auto;background:var(--danger);color:#fff;font-size:9px;padding:1px 5px;border-radius:7px;font-weight:700}
.sb-foot{margin-top:auto;padding:12px 14px;border-top:1px solid var(--border)}
.uav{width:28px;height:28px;background:var(--p);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.un{font-size:12px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ur{font-size:10px;color:var(--txt3)}
.lb{background:none;border:none;color:var(--txt3);padding:3px;border-radius:4px;width:auto;cursor:pointer}
.lb:hover{color:var(--danger)}

.main-layout{display:flex;flex:1;overflow:hidden;min-height:100vh}
.main-c{flex:1;overflow-y:auto;padding:22px 26px}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.topbar h1{font-size:19px;font-weight:700;color:var(--white)}
.topbar p{font-size:11px;color:var(--txt3);margin-top:2px}
.topbar-r{display:flex;align-items:center;gap:9px}
.nbtn{background:var(--card);border:1px solid var(--border);border-radius:var(--radius2);padding:7px 9px;color:var(--txt3);display:flex;align-items:center;position:relative;cursor:pointer}
.ndot{position:absolute;top:5px;right:5px;width:6px;height:6px;background:var(--danger);border-radius:50%;border:2px solid var(--bg)}
.live-pill{background:rgba(61,184,130,.12);border:1px solid rgba(61,184,130,.25);border-radius:20px;padding:4px 11px;font-size:11px;color:#5DEDB5;display:flex;align-items:center;gap:5px;font-weight:600}
.live-dot{width:5px;height:5px;background:#3DB882;border-radius:50%;animation:pulse 2s infinite}

.ticker-bar{background:var(--card3);border-bottom:1px solid var(--border);padding:6px 0;overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-flex;gap:40px;animation:ticker 30s linear infinite}
.ticker-item{font-size:11px;color:var(--txt3);display:inline-flex;align-items:center;gap:6px}
.ticker-item span{color:var(--p4);font-weight:600}
.ticker-item.danger span{color:#FFAAAA}
.ticker-item.ok span{color:#5DEDB5}

.sgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin-bottom:18px}
.sc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:17px;transition:all .18s;animation:fadeUp .4s ease forwards}
.sc:hover{border-color:var(--border2);transform:translateY(-2px)}
.sc-lbl{font-size:11px;color:var(--txt3);margin-bottom:3px}
.sc-val{font-size:22px;font-weight:700}
.sc-ch{font-size:11px;margin-top:3px}
.sc-ico{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.up{color:#5DEDB5}.dn{color:#FF8888}

.gc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;position:relative}
.gh{display:flex;align-items:center;justify-content:space-between;padding:13px 17px;border-bottom:1px solid var(--border)}
.gh h3{font-size:13px;font-weight:600;color:var(--white)}
.gtb{display:flex;gap:5px}
.tbtn{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius3);padding:4px 10px;color:var(--txt3);font-size:11px;font-weight:600;transition:all .16s;cursor:pointer}
.tbtn:hover,.tbtn.act{background:rgba(155,109,255,.18);border-color:var(--p3);color:var(--p3)}
.gleg{display:flex;gap:12px;padding:9px 17px;border-top:1px solid var(--border);flex-wrap:wrap}
.gli{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--txt3)}
.gld{width:8px;height:8px;border-radius:50%}

.al-item{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;background:var(--card3);border:1px solid var(--border);border-radius:var(--radius2);margin-bottom:7px;animation:slideR .3s ease forwards}
.al-item.critical{border-left:3px solid var(--danger);background:#160610}
.al-item.warning{border-left:3px solid var(--warn);background:#180E00}
.al-item.info{border-left:3px solid var(--p3);background:#10072A}
.al-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px;animation:blink 1.4s infinite}
.al-dot.critical{background:var(--danger)}
.al-dot.warning{background:var(--warn)}
.al-dot.info{background:var(--p3)}
.al-title{font-size:12px;font-weight:600;color:var(--white);margin-bottom:2px}
.al-desc{font-size:11px;color:var(--txt2);line-height:1.5}

.tw-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{padding:8px 12px;text-align:left;color:var(--txt3);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border)}
tbody tr{border-bottom:1px solid rgba(180,140,255,.04);transition:background .1s}
tbody tr:hover{background:rgba(180,140,255,.04)}
tbody td{padding:10px 12px;color:var(--txt2)}
tbody td:first-child{color:var(--white);font-weight:500}

.two-col{display:grid;grid-template-columns:1fr 320px;gap:16px;margin-bottom:18px}
.page-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.page-hdr h2{font-size:17px;font-weight:700;color:var(--white)}

.ugrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:14px}
.ucard{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all .18s}
.ucard:hover{border-color:var(--border2);transform:translateY(-2px)}
.ucard-top{padding:16px 16px 13px;border-bottom:1px solid var(--border)}
.ucard-av{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;flex-shrink:0}
.ucard-body{padding:13px 16px}
.ucard-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(180,140,255,.05)}
.ucard-row:last-child{border-bottom:none}
.ucard-key{font-size:11px;color:var(--txt3)}
.ucard-val{font-size:11px;color:var(--txt);font-weight:500;text-align:right;font-family:monospace}
.ucard-foot{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:7px;justify-content:space-between}

.agrid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:14px}
.ccrd{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:17px}
.ccrd h3{font-size:12px;font-weight:600;color:var(--txt2);margin-bottom:12px}

.set-layout{display:grid;grid-template-columns:180px 1fr;gap:14px}
.set-nav{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:9px;height:fit-content}
.sni{padding:7px 10px;border-radius:var(--radius3);font-size:12px;color:var(--txt3);transition:all .16s;display:flex;align-items:center;gap:6px;font-weight:500;cursor:pointer}
.sni:hover,.sni.act{background:rgba(155,109,255,.14);color:var(--p4)}
.set-con{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px}
.ss{margin-bottom:22px}
.ss h3{font-size:13px;font-weight:600;color:var(--white);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.sr{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(180,140,255,.04)}
.sr:last-child{border-bottom:none}
.sr-info strong{display:block;font-size:12px;font-weight:500;color:var(--txt);margin-bottom:1px}
.sr-info span{font-size:11px;color:var(--txt3)}
.tog{width:36px;height:19px;background:var(--bg3);border-radius:10px;position:relative;transition:background .18s;border:1px solid var(--border2);flex-shrink:0;cursor:pointer}
.tog.on{background:var(--p)}
.tog::after{content:'';position:absolute;width:13px;height:13px;background:#fff;border-radius:50%;top:2px;left:2px;transition:left .16s}
.tog.on::after{left:19px}

.modal-bg{display:none;position:absolute;inset:0;background:rgba(5,2,14,.88);z-index:1000;align-items:center;justify-content:center;min-height:600px}
.modal-bg.open{display:flex}
.modal{background:var(--card2);border:1px solid var(--border3);border-radius:var(--radius);width:580px;max-height:86vh;overflow-y:auto;padding:26px}
.modal h2{font-size:17px;font-weight:700;color:var(--white);margin-bottom:3px}
.modal-sub{font-size:11px;color:var(--txt3);margin-bottom:20px}
.ms-title{font-size:10px;font-weight:700;color:var(--p4);text-transform:uppercase;letter-spacing:.6px;margin-bottom:11px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.ms{margin-bottom:18px}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
.two-col-f{display:grid;grid-template-columns:1fr 1fr;gap:9px}

.risk-mini{display:inline-block;width:60px;height:4px;background:var(--bg3);border-radius:2px;vertical-align:middle}
.risk-fill{height:100%;border-radius:2px;display:block}

.pulse-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:20px;font-size:10px;font-weight:700}
.pulse-badge.live{background:rgba(61,184,130,.12);border:1px solid rgba(61,184,130,.25);color:#5DEDB5}
.pulse-badge.alert{background:rgba(224,85,85,.12);border:1px solid rgba(224,85,85,.25);color:#FFAAAA}
.pulse-badge.watch{background:rgba(201,136,26,.12);border:1px solid rgba(201,136,26,.25);color:#FFD070}

.heatmap-cell{display:inline-block;border-radius:3px;transition:opacity .2s}
.heatmap-cell:hover{opacity:.7}

.filter-bar{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.filter-bar input,.filter-bar select{max-width:190px}
</style>

<div id="app-wrap" style="position:relative;min-height:100vh;background:var(--bg)">
<div class="toast-wrap" id="toasts"></div>

<div class="modal-bg" id="addUserModal">
<div class="modal au">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px">
    <h2>Register new client</h2>
    <button class="bo" style="padding:5px 9px;font-size:17px" onclick="closeModal()">×</button>
  </div>
  <div class="modal-sub">All starred fields required — data synced to TigerGraph schema</div>
  <div class="ms"><div class="ms-title">Personal information</div>
    <div class="three-col" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">First name *</label><input type="text" id="m-fn" placeholder="Riya"></div>
      <div class="fgroup"><label class="flabel">Last name *</label><input type="text" id="m-ln" placeholder="Sharma"></div>
      <div class="fgroup"><label class="flabel">Date of birth</label><input type="date" id="m-dob"></div>
    </div>
    <div class="two-col-f" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">Email *</label><input type="email" id="m-em" placeholder="riya@email.com"></div>
      <div class="fgroup"><label class="flabel">Phone *</label><input type="tel" id="m-ph" placeholder="+91 98765 43210"></div>
    </div>
    <div class="fgroup"><label class="flabel">Address</label><input type="text" id="m-addr" placeholder="Flat No, Street, City, State, PIN"></div>
  </div>
  <div class="ms"><div class="ms-title">Identity & KYC</div>
    <div class="three-col" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">PAN *</label><input type="text" id="m-pan" placeholder="ABCDE1234F" maxlength="10" style="text-transform:uppercase"></div>
      <div class="fgroup"><label class="flabel">Aadhaar</label><input type="text" id="m-aadh" placeholder="XXXX XXXX XXXX" maxlength="14"></div>
      <div class="fgroup"><label class="flabel">Passport</label><input type="text" id="m-pass" placeholder="A1234567"></div>
    </div>
    <div class="two-col-f">
      <div class="fgroup"><label class="flabel">KYC status</label><select id="m-kyc"><option value="verified">Verified</option><option value="pending">Pending</option><option value="rejected">Rejected</option></select></div>
      <div class="fgroup"><label class="flabel">Nationality</label><input type="text" id="m-nat" placeholder="Indian" value="Indian"></div>
    </div>
  </div>
  <div class="ms"><div class="ms-title">Bank account details</div>
    <div class="two-col-f" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">Account number *</label><input type="text" id="m-acc" placeholder="1234 5678 9012 3456" maxlength="19"></div>
      <div class="fgroup"><label class="flabel">Confirm account no.</label><input type="text" id="m-acc2" placeholder="Re-enter" maxlength="19"></div>
    </div>
    <div class="three-col" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">IFSC *</label><input type="text" id="m-ifsc" placeholder="HDFC0001234" maxlength="11" style="text-transform:uppercase"></div>
      <div class="fgroup"><label class="flabel">Bank name *</label><input type="text" id="m-bank" placeholder="HDFC Bank"></div>
      <div class="fgroup"><label class="flabel">Branch</label><input type="text" id="m-branch" placeholder="Connaught Place"></div>
    </div>
    <div class="two-col-f">
      <div class="fgroup"><label class="flabel">Account type</label><select id="m-atype"><option>Savings</option><option>Current</option><option>Fixed Deposit</option><option>NRI</option></select></div>
      <div class="fgroup"><label class="flabel">MICR code</label><input type="text" id="m-micr" placeholder="110240001" maxlength="9"></div>
    </div>
  </div>
  <div class="ms"><div class="ms-title">Device & security</div>
    <div class="three-col" style="margin-bottom:9px">
      <div class="fgroup"><label class="flabel">Device ID</label><input type="text" id="m-dev" placeholder="iOS-A1B2C3D4"></div>
      <div class="fgroup"><label class="flabel">IP address</label><input type="text" id="m-ip" placeholder="103.25.146.20"></div>
      <div class="fgroup"><label class="flabel">Risk tier</label><select id="m-risk"><option value="low">Low</option><option value="medium">Medium</option><option value="high">High</option></select></div>
    </div>
